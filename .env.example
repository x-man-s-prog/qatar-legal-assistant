# ═══════════════════════════════════════════════
# المساعد القانوني — إعدادات التشغيل
# ═══════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم
# cp .env.example .env

# 🔑 مفتاح OpenAI / ChatGPT (النموذج الرئيسي)
OPENAI_API_KEY=sk-your-openai-key-here
MODEL_OPENAI=gpt-4o

# 🔑 مفتاح Gemini (احتياطي)
GEMINI_API_KEY=AIza-your-gemini-key-here
MODEL_GEMINI=gemini-2.0-flash

# 🔑 مفتاح Claude (اختياري)
ANTHROPIC_API_KEY=

# 🗄️ قاعدة البيانات
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragdb
DB_USER=raguser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# 🤖 Ollama (اختياري)
OLLAMA_HOST=http://localhost:11434
MODEL_EMBED=nomic-embed-text
MODEL_OLLAMA_LLM=qwen2.5:1.5b

# 🧠 نماذج Claude (احتياطية)
MODEL_MAIN=claude-3-5-sonnet-20241022
MODEL_FAST=claude-3-haiku-20240307

# 🌐 CORS — النطاقات المسموح بها
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 🔒 Redis (اختياري)
REDIS_URL=redis://localhost:6379/0

# 🔑 مفاتيح الأمان — ولّدها بـ: openssl rand -hex 32
API_KEY=GENERATE_NEW_KEY_HERE
JWT_SECRET=GENERATE_NEW_KEY_HERE

# ⚡ Rate Limiting
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# 📊 Observability (Sentry)
# SENTRY_DSN=https://your-key@sentry.io/project-id
# ENVIRONMENT=production
# SENTRY_TRACES_RATE=0.2
