# ═══════════════════════════════════════════════
# المساعد القانوني — إعدادات التشغيل المحلي
# ═══════════════════════════════════════════════
# ⚠️ هذا الملف لا يُرفع على Git — أضفه إلى .gitignore

# 🔑 مفتاح OpenAI / ChatGPT (النموذج الرئيسي)
# ⚠️ أنشئ مفتاح جديد من https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_KEY
MODEL_OPENAI=gpt-4o

# 🔑 مفتاح Gemini (احتياطي)
# ⚠️ أنشئ مفتاح جديد من https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
MODEL_GEMINI=gemini-2.0-flash

# 🔑 مفتاح Claude (معطّل)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# 🗄️ قاعدة البيانات
DB_HOST=legal_db
DB_PORT=5432
DB_NAME=ragdb
DB_USER=raguser
DB_PASSWORD=change_me_in_production

# 🤖 Ollama (اختياري)
OLLAMA_HOST=http://localhost:11434
MODEL_EMBED=nomic-embed-text
MODEL_OLLAMA_LLM=qwen2.5:1.5b

# 🧠 نماذج Claude (احتياطية)
MODEL_MAIN=claude-3-5-sonnet-20241022
MODEL_FAST=claude-3-haiku-20240307

# 🌐 CORS
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 🔒 Redis
# REDIS_URL=redis://localhost:6379/0

# 🔑 مفاتيح الأمان — ولّدها بـ: openssl rand -hex 32
API_KEY=your_app_api_key_here
JWT_SECRET=your_jwt_secret_here

# 📊 Observability (Sentry)
# SENTRY_DSN=https://your-key@sentry.io/project-id
# ENVIRONMENT=production
# SENTRY_TRACES_RATE=0.2
