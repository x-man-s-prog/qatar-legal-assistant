# ═══════════════════════════════════════════════════════════════
# .env.production.template — قالب إعدادات الإنتاج
# ═══════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعبّئ القيم الحقيقية:
#   cp .env.production.template .env
#
# تحقق من الجاهزية:
#   python scripts/check_env.py
#
# ⚠️  لا ترفع ملف .env إلى git أبداً!
# ═══════════════════════════════════════════════════════════════

# ── قاعدة البيانات ─────────────────────────────────────────────
# صيغة كاملة: postgresql://user:pass@host:port/dbname
DATABASE_URL=postgresql://user:pass@db:5432/legal_rag

# أو متغيرات منفصلة (إذا لم يُستخدم DATABASE_URL)
DB_HOST=db
DB_PORT=5432
DB_NAME=legal_rag
DB_USER=raguser
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── نماذج LLM ──────────────────────────────────────────────────
# OpenAI — احصل عليه من: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini — احصل عليه من: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# Anthropic Claude — احصل عليه من: https://console.anthropic.com/
ANTHROPIC_API_KEY=...

# Ollama — اللغة المحلية (لا مفتاح مطلوب)
OLLAMA_HOST=http://ollama:11434
MODEL_OLLAMA_LLM=qwen2.5:1.5b

# أسماء النماذج (اختياري — القيم الافتراضية محددة أدناه)
MODEL_MAIN=claude-3-5-sonnet-20241022
MODEL_FAST=claude-3-haiku-20240307
MODEL_GEMINI=gemini-2.0-flash
MODEL_OPENAI=gpt-4o

# ── الأمان ─────────────────────────────────────────────────────
# أنشئ مفتاحاً عشوائياً قوياً:
#   openssl rand -hex 32
API_KEY=<generate: openssl rand -hex 32>

# سر JWT — يجب أن يكون 32+ بايت عشوائي:
#   openssl rand -hex 32
JWT_SECRET=<generate: openssl rand -hex 32>

# ── Redis (اختياري — للـ rate limiter متعدد العمال) ─────────────
# اتركه فارغاً لاستخدام In-Memory fallback
REDIS_URL=redis://redis:6379/0

# ── CORS ───────────────────────────────────────────────────────
# قائمة بفواصل من الأصول المسموحة (بدون مسافات)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── بيئة التشغيل ───────────────────────────────────────────────
# dev | staging | production
APP_ENV=production
APP_PORT=8000

# ── الإعدادات المتقدمة ──────────────────────────────────────────
# عدد worker processes لـ Gunicorn
WORKERS=4

# مهلة الطلب بالثواني
REQUEST_TIMEOUT=120

# حجم البيانات الكاشة (ميغابايت)
CACHE_MAX_MB=512
